<Window x:Class="EJournalAutomate.Views.Windows.DevKeySettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EJournalAutomate.Views.Windows"
        mc:Ignorable="d"
        Title="EJournal Automate" Height="100" Width="800" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel VerticalAlignment="Center">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Введите DevKey:" Grid.Column="0" FontSize="14" TextAlignment="Center"/>
            <TextBox x:Name="DevKeyTextBox" Grid.Column="1" VerticalContentAlignment="Center" FontSize="14"/>
        </Grid>
        <Button x:Name="SetDevKeyButton" Content="Сохранить ключ" FontSize="14" Width="120" Margin="0,10,0,0" Click="SetDevKeyButton_Click"/>
    </StackPanel>
</Window>

